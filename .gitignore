# --- Secrets ---
.env
.env.local
.env.*.local

# --- Claude Code local state ---
.claude/

# --- Local-only data ---
# Production / legacy DB dumps live locally, never in source control
database/live_dump*.sql
database/*_dump*.sql
database/*.dump

# --- Dependencies ---
/vendor/
/node_modules/

# --- Build / cache ---
/cache/
/tmp/
*.log

# --- User uploads (runtime data, not source) ---
# Folder is gitignored, but the .htaccess + .gitkeep that establish the
# folder + its PHP-execution lockdown ARE tracked.
/uploads/*
!/uploads/.htaccess
!/uploads/.gitkeep
/public/uploads/

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Composer ---
composer.phar
