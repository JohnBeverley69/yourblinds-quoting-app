# YourBlinds — environment variable template
# Copy to .env and fill in real values. .env is gitignored.

# Application
APP_ENV=production            # production | development
APP_TIMEZONE=Europe/London
# Canonical public URL — used to build absolute links in outbound email
# (e.g. password-reset). MUST be set on production: relying on the request's
# Host header would let an attacker spoof reset URLs via a forged Host: header.
APP_URL=https://yourblinds.uk

# Database
DB_HOST=localhost
DB_NAME=yourblinds
DB_USER=yourblinds_app
DB_PASS=change-me
DB_PORT=3306
DB_CHARSET=utf8mb4

# Outbound email (SMTP). Used by auth/forgot_password.php and quote sending.
# AuthSMTP common ports: 25, 2525 (plain/STARTTLS), 587 (STARTTLS), 465 (SMTPS).
MAIL_HOST=mail.authsmtp.com
MAIL_PORT=2525
MAIL_USERNAME=your-smtp-username
MAIL_PASS=your-smtp-password
MAIL_FROM=noreply@yourblinds.uk
MAIL_FROM_NAME=YourBlinds

# Google Maps — used by the calendar module for route planning between
# appointments. Get a key at https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Postcoder — UK postcode → address lookup on booking forms.
# Pay-as-you-go credits, no monthly minimum. Sign up at https://postcoder.com
POSTCODER_API_KEY=your_postcoder_key
